{
  "name": "Debian + Claude Code",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/node:2.1.0": {
      "version": "lts"
    }
  },
  "remoteUser": "app",
  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/app/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/app/.claude"
  },
  "remoteEnv": {
    "PATH": "/home/app/.npm-global/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "mkdir -p ~/.npm-global && npm config set prefix ~/.npm-global && npm install -g @anthropic-ai/claude-code'"
}
